            "args": {
                "dtype": "float32",
                "num_iteration": 20,
                "batch_size": 4,
                "sequence_length": 64,
                "total_batch_size": 256,
                "overfit_single_batch": false
            }
        },
        {
            "id": "flash_fp32_seq64",
            "args": {
                "dtype": "float32",
                "num_iteration": 20,
                "batch_size": 4,
                "sequence_length": 64,
                "total_batch_size": 256,
                "overfit_single_batch": false,
                "flash": true
            }
        },
        {
            "id": "baseline_fp32_seq256",
            "args": {
                "dtype": "float32",
                "num_iteration": 20,
                "batch_size": 4,
                "sequence_length": 256,
